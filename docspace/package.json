{
  "name": "docspace-workspace",
  "displayName": "Docspace Workspace",
  "description": "Visualize and manage Markdown, Mermaid diagrams and Excalidraw canvases inside VS Code.",
  "publisher": "ArthurSilv4",
  "version": "0.0.6",
  "engines": {
    "vscode": "^1.120.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "docspace.openPreview",
        "title": "Open Preview"
      },
      {
        "command": "docspace.selectDiagramTheme",
        "title": "Change Diagram Theme",
        "icon": "$(symbol-color)"
      },
      {
        "command": "docspace.configureCategory",
        "title": "Configurar Categoria…",
        "icon": "$(gear)"
      },
      {
        "command": "docspace.regenerateDoc",
        "title": "Regenerar Doc",
        "icon": "$(book)"
      },
      {
        "command": "docspace.selectSort",
        "title": "Ordenar arquivos",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "docspace.notionConnect",
        "title": "Notion: Conectar",
        "icon": "$(plug)"
      },
      {
        "command": "docspace.notionImport",
        "title": "Notion: Importar páginas",
        "icon": "$(cloud-download)"
      },
      {
        "command": "docspace.notionPull",
        "title": "Notion: Puxar (pull)"
      },
      {
        "command": "docspace.notionPush",
        "title": "Notion: Enviar (push)"
      },
      {
        "command": "docspace.notionDisconnect",
        "title": "Notion: Desconectar",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "docspace.openProjectGraph",
        "title": "Open Project Graph",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "docspace.newMarkdown",
        "title": "New Markdown File",
        "icon": "$(new-file)"
      },
      {
        "command": "docspace.newMermaid",
        "title": "New Mermaid Diagram",
        "icon": "$(new-file)"
      },
      {
        "command": "docspace.newExcalidraw",
        "title": "New Canvas",
        "icon": "$(new-file)"
      },
      {
        "command": "docspace.deleteFile",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "docspace.renameFile",
        "title": "Rename",
        "icon": "$(edit)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "docspace.configureCategory",
          "when": "view == docspace.explorer && viewItem =~ /^dsCat_/",
          "group": "docspace@0"
        },
        {
          "command": "docspace.newMarkdown",
          "when": "view == docspace.explorer && viewItem == dsCat_docs",
          "group": "docspace@1"
        },
        {
          "command": "docspace.newMarkdown",
          "when": "view == docspace.explorer && viewItem == dsFolder",
          "group": "docspace@1"
        },
        {
          "command": "docspace.newMermaid",
          "when": "view == docspace.explorer && viewItem == dsCat_diagrams",
          "group": "docspace@2"
        },
        {
          "command": "docspace.newMermaid",
          "when": "view == docspace.explorer && viewItem == dsFolder",
          "group": "docspace@2"
        },
        {
          "command": "docspace.newExcalidraw",
          "when": "view == docspace.explorer && viewItem == dsCat_canvas",
          "group": "docspace@3"
        },
        {
          "command": "docspace.newExcalidraw",
          "when": "view == docspace.explorer && viewItem == dsFolder",
          "group": "docspace@3"
        },
        {
          "command": "docspace.deleteFile",
          "when": "view == docspace.explorer && viewItem =~ /^(dsFile|dsFolder)$/",
          "group": "inline"
        },
        {
          "command": "docspace.renameFile",
          "when": "view == docspace.explorer && viewItem =~ /^(dsFile|dsFolder)$/",
          "group": "docspace@8"
        }
      ],
      "view/title": [
        {
          "command": "docspace.openProjectGraph",
          "when": "view == docspace.explorer",
          "group": "navigation@1"
        },
        {
          "command": "docspace.regenerateDoc",
          "when": "view == docspace.explorer",
          "group": "navigation@2"
        },
        {
          "command": "docspace.notionConnect",
          "when": "view == docspace.explorer && !docspace.notionConnected",
          "group": "navigation@3"
        },
        {
          "command": "docspace.notionDisconnect",
          "when": "view == docspace.explorer && docspace.notionConnected",
          "group": "navigation@3"
        },
        {
          "command": "docspace.notionImport",
          "when": "view == docspace.explorer && docspace.notionConnected",
          "group": "navigation@4"
        },
        {
          "command": "docspace.selectSort",
          "when": "view == docspace.explorer",
          "group": "navigation@5"
        },
        {
          "command": "docspace.selectDiagramTheme",
          "when": "view == docspace.explorer",
          "group": "navigation@6"
        }
      ]
    },
    "configuration": {
      "title": "Docspace",
      "properties": {
        "docspace.docsMode": {
          "type": "string",
          "enum": ["auto", "folder"],
          "enumDescriptions": [
            "Descobre arquivos .md (e .md com Mermaid) em todo o projeto.",
            "Mostra apenas os arquivos da pasta definida em docspace.docsFolder."
          ],
          "default": "auto",
          "description": "Modo de descoberta da categoria Docs."
        },
        "docspace.docsFolder": {
          "type": "string",
          "default": "",
          "description": "Pasta usada pela categoria Docs no modo 'folder'. Caminho relativo ao workspace ou absoluto."
        },
        "docspace.diagramsMode": {
          "type": "string",
          "enum": ["auto", "folder"],
          "enumDescriptions": [
            "Descobre arquivos .mmd e .md com blocos Mermaid em todo o projeto.",
            "Mostra apenas os arquivos da pasta definida em docspace.diagramsFolder."
          ],
          "default": "auto",
          "description": "Modo de descoberta da categoria Diagrams."
        },
        "docspace.diagramsFolder": {
          "type": "string",
          "default": "",
          "description": "Pasta usada pela categoria Diagrams no modo 'folder'. Caminho relativo ao workspace ou absoluto."
        },
        "docspace.canvasMode": {
          "type": "string",
          "enum": ["auto", "folder"],
          "enumDescriptions": [
            "Descobre arquivos .excalidraw em todo o projeto.",
            "Mostra apenas os arquivos da pasta definida em docspace.canvasFolder."
          ],
          "default": "auto",
          "description": "Modo de descoberta da categoria Canvas."
        },
        "docspace.canvasFolder": {
          "type": "string",
          "default": "",
          "description": "Pasta usada pela categoria Canvas no modo 'folder'. Caminho relativo ao workspace ou absoluto."
        },
        "docspace.notionToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "Internal Integration Token do Notion (criado em https://www.notion.so/my-integrations). Guardado nas configurações do usuário, fora do repositório.",
          "scope": "application"
        },
        "docspace.notionPollMinutes": {
          "type": "number",
          "default": 5,
          "minimum": 0,
          "description": "Intervalo (minutos) do sync automático de páginas vinculadas ao Notion. 0 desativa o polling."
        },
        "docspace.sortBy": {
          "type": "string",
          "enum": ["name", "modified", "size"],
          "enumDescriptions": [
            "Ordem alfabética.",
            "Modificados mais recentemente primeiro.",
            "Maiores primeiro."
          ],
          "default": "name",
          "description": "Critério de ordenação dos arquivos na sidebar."
        },
        "docspace.diagramTheme": {
          "type": "string",
          "enum": [
            "auto",
            "default",
            "dark",
            "forest",
            "neutral",
            "base"
          ],
          "enumDescriptions": [
            "Detecta o tema do VS Code automaticamente (claro → default, escuro → dark).",
            "Tema padrão do Mermaid.",
            "Tema escuro.",
            "Tema floresta (tons de verde).",
            "Tema neutro (tons de cinza).",
            "Tema base personalizável."
          ],
          "default": "auto",
          "description": "Tema dos diagramas Mermaid no preview."
        },
        "docspace.graphTheme": {
          "type": "string",
          "enum": [
            "auto",
            "obsidian",
            "blueprint",
            "pastel",
            "high-contrast"
          ],
          "enumDescriptions": [
            "Segue o tema do VS Code.",
            "Fundo escuro, nós coloridos com tons suaves.",
            "Fundo azul escuro, nós e edges em azul claro/branco.",
            "Fundo claro, nós em cores pastel suaves.",
            "Fundo preto, cores vibrantes, máximo contraste."
          ],
          "default": "auto",
          "description": "Tema visual do Project Graph."
        },
        "docspace.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "node_modules",
            ".git",
            "out",
            "dist"
          ],
          "description": "Pastas a ignorar na descoberta de arquivos."
        }
      }
    },
    "customEditors": [
      {
        "viewType": "docspace.canvasEditor",
        "displayName": "Docspace Canvas",
        "selector": [{ "filenamePattern": "*.excalidraw" }],
        "priority": "default"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "docspace-sidebar",
          "title": "Docspace",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "docspace-sidebar": [
        {
          "id": "docspace.explorer",
          "name": "Docspace"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "docspace.explorer",
        "contents": "Nenhum documento encontrado.\n[Novo Markdown](command:docspace.newMarkdown)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
