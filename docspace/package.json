{
  "name": "docspace-workspace",
  "displayName": "%displayName%",
  "description": "%description%",
  "publisher": "ArthurSilv4",
  "version": "0.0.7",
  "license": "SEE LICENSE IN LICENSE.txt",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.120.0"
  },
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "keywords": [
    "markdown",
    "mermaid",
    "excalidraw",
    "diagram",
    "documentation",
    "graph",
    "dependency",
    "notion",
    "preview",
    "canvas"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "categories": [
    "Visualization",
    "Other"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "docspace.openPreview",
        "title": "%command.openPreview.title%"
      },
      {
        "command": "docspace.selectDiagramTheme",
        "title": "%command.selectDiagramTheme.title%",
        "icon": "$(symbol-color)"
      },
      {
        "command": "docspace.configureCategory",
        "title": "%command.configureCategory.title%",
        "icon": "$(gear)"
      },
      {
        "command": "docspace.regenerateDoc",
        "title": "%command.regenerateDoc.title%",
        "icon": "$(book)"
      },
      {
        "command": "docspace.selectSort",
        "title": "%command.selectSort.title%",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "docspace.notionConnect",
        "title": "%command.notionConnect.title%",
        "icon": "$(plug)"
      },
      {
        "command": "docspace.notionImport",
        "title": "%command.notionImport.title%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "docspace.notionPull",
        "title": "%command.notionPull.title%"
      },
      {
        "command": "docspace.notionPush",
        "title": "%command.notionPush.title%"
      },
      {
        "command": "docspace.notionDisconnect",
        "title": "%command.notionDisconnect.title%",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "docspace.openProjectGraph",
        "title": "%command.openProjectGraph.title%",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "docspace.newMarkdown",
        "title": "%command.newMarkdown.title%",
        "icon": "$(new-file)"
      },
      {
        "command": "docspace.newMermaid",
        "title": "%command.newMermaid.title%",
        "icon": "$(new-file)"
      },
      {
        "command": "docspace.newExcalidraw",
        "title": "%command.newExcalidraw.title%",
        "icon": "$(new-file)"
      },
      {
        "command": "docspace.deleteFile",
        "title": "%command.deleteFile.title%",
        "icon": "$(trash)"
      },
      {
        "command": "docspace.renameFile",
        "title": "%command.renameFile.title%",
        "icon": "$(edit)"
      },
      {
        "command": "docspace.showWelcome",
        "title": "%command.showWelcome.title%",
        "icon": "$(question)"
      },
      {
        "command": "docspace.openSettings",
        "title": "%command.openSettings.title%",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "docspace.configureCategory",
          "when": "view == docspace.explorer && viewItem =~ /^dsCat_/",
          "group": "docspace@0"
        },
        {
          "command": "docspace.newMarkdown",
          "when": "view == docspace.explorer && viewItem == dsCat_docs",
          "group": "docspace@1"
        },
        {
          "command": "docspace.newMarkdown",
          "when": "view == docspace.explorer && viewItem == dsFolder",
          "group": "docspace@1"
        },
        {
          "command": "docspace.newMermaid",
          "when": "view == docspace.explorer && viewItem == dsCat_diagrams",
          "group": "docspace@2"
        },
        {
          "command": "docspace.newMermaid",
          "when": "view == docspace.explorer && viewItem == dsFolder",
          "group": "docspace@2"
        },
        {
          "command": "docspace.newExcalidraw",
          "when": "view == docspace.explorer && viewItem == dsCat_canvas",
          "group": "docspace@3"
        },
        {
          "command": "docspace.newExcalidraw",
          "when": "view == docspace.explorer && viewItem == dsFolder",
          "group": "docspace@3"
        },
        {
          "command": "docspace.deleteFile",
          "when": "view == docspace.explorer && viewItem =~ /^(dsFile|dsFolder|dsGenFolder)$/",
          "group": "inline"
        },
        {
          "command": "docspace.renameFile",
          "when": "view == docspace.explorer && viewItem =~ /^(dsFile|dsFolder)$/",
          "group": "docspace@8"
        }
      ],
      "view/title": [
        {
          "command": "docspace.openSettings",
          "when": "view == docspace.explorer",
          "group": "navigation@1"
        },
        {
          "command": "docspace.showWelcome",
          "when": "view == docspace.explorer",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "Docspace",
      "properties": {
        "docspace.docsMode": {
          "type": "string",
          "enum": [
            "auto",
            "folder"
          ],
          "enumDescriptions": [
            "Descobre arquivos .md (e .md com Mermaid) em todo o projeto.",
            "Mostra apenas os arquivos da pasta definida em docspace.docsFolder."
          ],
          "default": "auto",
          "description": "Modo de descoberta da categoria Docs."
        },
        "docspace.docsFolder": {
          "type": "string",
          "default": "",
          "description": "Pasta usada pela categoria Docs no modo 'folder'. Caminho relativo ao workspace ou absoluto."
        },
        "docspace.diagramsMode": {
          "type": "string",
          "enum": [
            "auto",
            "folder"
          ],
          "enumDescriptions": [
            "Descobre arquivos .mmd e .md com blocos Mermaid em todo o projeto.",
            "Mostra apenas os arquivos da pasta definida em docspace.diagramsFolder."
          ],
          "default": "auto",
          "description": "Modo de descoberta da categoria Diagrams."
        },
        "docspace.diagramsFolder": {
          "type": "string",
          "default": "",
          "description": "Pasta usada pela categoria Diagrams no modo 'folder'. Caminho relativo ao workspace ou absoluto."
        },
        "docspace.canvasMode": {
          "type": "string",
          "enum": [
            "auto",
            "folder"
          ],
          "enumDescriptions": [
            "Descobre arquivos .excalidraw em todo o projeto.",
            "Mostra apenas os arquivos da pasta definida em docspace.canvasFolder."
          ],
          "default": "auto",
          "description": "Modo de descoberta da categoria Canvas."
        },
        "docspace.canvasFolder": {
          "type": "string",
          "default": "",
          "description": "Pasta usada pela categoria Canvas no modo 'folder'. Caminho relativo ao workspace ou absoluto."
        },
        "docspace.notionToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "Internal Integration Token do Notion (criado em https://www.notion.so/my-integrations). Guardado nas configurações do usuário, fora do repositório.",
          "scope": "application"
        },
        "docspace.notionPollMinutes": {
          "type": "number",
          "default": 5,
          "minimum": 0,
          "description": "Intervalo (minutos) do sync automático de páginas vinculadas ao Notion. 0 desativa o polling."
        },
        "docspace.sortBy": {
          "type": "string",
          "enum": [
            "name",
            "modified",
            "size"
          ],
          "enumDescriptions": [
            "Ordem alfabética.",
            "Modificados mais recentemente primeiro.",
            "Maiores primeiro."
          ],
          "default": "name",
          "description": "Critério de ordenação dos arquivos na sidebar."
        },
        "docspace.diagramTheme": {
          "type": "string",
          "enum": [
            "auto",
            "default",
            "dark",
            "forest",
            "neutral",
            "base"
          ],
          "enumDescriptions": [
            "Detecta o tema do VS Code automaticamente (claro → default, escuro → dark).",
            "Tema padrão do Mermaid.",
            "Tema escuro.",
            "Tema floresta (tons de verde).",
            "Tema neutro (tons de cinza).",
            "Tema base personalizável."
          ],
          "default": "auto",
          "description": "Tema dos diagramas Mermaid no preview."
        },
        "docspace.graphTheme": {
          "type": "string",
          "enum": [
            "auto",
            "obsidian",
            "blueprint",
            "pastel",
            "high-contrast"
          ],
          "enumDescriptions": [
            "Segue o tema do VS Code.",
            "Fundo escuro, nós coloridos com tons suaves.",
            "Fundo azul escuro, nós e edges em azul claro/branco.",
            "Fundo claro, nós em cores pastel suaves.",
            "Fundo preto, cores vibrantes, máximo contraste."
          ],
          "default": "auto",
          "description": "Tema visual do Project Graph."
        },
        "docspace.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "node_modules",
            ".git",
            "out",
            "dist"
          ],
          "description": "Pastas a ignorar na descoberta de arquivos."
        }
      }
    },
    "customEditors": [
      {
        "viewType": "docspace.canvasEditor",
        "displayName": "Docspace Canvas",
        "selector": [
          {
            "filenamePattern": "*.excalidraw"
          }
        ],
        "priority": "default"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "docspace-sidebar",
          "title": "Docspace",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "docspace-sidebar": [
        {
          "id": "docspace.explorer",
          "name": "Docspace"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "docspace.explorer",
        "contents": "%viewsWelcome.contents%"
      }
    ],
    "walkthroughs": [
      {
        "id": "docspace.onboarding",
        "title": "%walkthrough.title%",
        "description": "%walkthrough.description%",
        "steps": [
          {
            "id": "docspace.onboarding.sidebar",
            "title": "%walkthrough.step.sidebar.title%",
            "description": "%walkthrough.step.sidebar.description%",
            "media": {
              "image": {
                "dark": "media/walkthrough/sidebar-dark.svg",
                "light": "media/walkthrough/sidebar-light.svg",
                "hc": "media/walkthrough/sidebar-dark.svg"
              },
              "altText": "%walkthrough.step.sidebar.altText%"
            },
            "completionEvents": [
              "onCommand:docspace.newMarkdown",
              "onCommand:docspace.newMermaid",
              "onCommand:docspace.newExcalidraw"
            ]
          },
          {
            "id": "docspace.onboarding.preview",
            "title": "%walkthrough.step.preview.title%",
            "description": "%walkthrough.step.preview.description%",
            "media": {
              "image": {
                "dark": "media/walkthrough/preview-dark.svg",
                "light": "media/walkthrough/preview-light.svg",
                "hc": "media/walkthrough/preview-dark.svg"
              },
              "altText": "%walkthrough.step.preview.altText%"
            },
            "completionEvents": [
              "onCommand:docspace.openPreview"
            ]
          },
          {
            "id": "docspace.onboarding.graph",
            "title": "%walkthrough.step.graph.title%",
            "description": "%walkthrough.step.graph.description%",
            "media": {
              "image": {
                "dark": "media/walkthrough/graph-dark.svg",
                "light": "media/walkthrough/graph-light.svg",
                "hc": "media/walkthrough/graph-dark.svg"
              },
              "altText": "%walkthrough.step.graph.altText%"
            },
            "completionEvents": [
              "onCommand:docspace.openProjectGraph"
            ]
          },
          {
            "id": "docspace.onboarding.generate",
            "title": "%walkthrough.step.generate.title%",
            "description": "%walkthrough.step.generate.description%",
            "media": {
              "image": {
                "dark": "media/walkthrough/generate-dark.svg",
                "light": "media/walkthrough/generate-light.svg",
                "hc": "media/walkthrough/generate-dark.svg"
              },
              "altText": "%walkthrough.step.generate.altText%"
            },
            "completionEvents": [
              "onCommand:docspace.regenerateDoc"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "l10n:extract": "npx @vscode/l10n-dev export --outDir ./l10n ./src",
    "package": "vsce package --allow-missing-repository",
    "release:patch": "node scripts/release.mjs prepare patch",
    "release:minor": "node scripts/release.mjs prepare minor",
    "release:major": "node scripts/release.mjs prepare major",
    "release:finish": "node scripts/release.mjs finish"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/l10n-dev": "^0.0.35",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.2.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
